# ============================================================
#  TacticalOps Backend — Environment Config
#  Copy this to backend/.env and edit values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# dump1090 (ADS-B)
# If dump1090 is running locally, leave as default
DUMP1090_HOST=127.0.0.1
DUMP1090_PORT=30003

# rtl_433 binary path
# On Raspberry Pi OS: usually /usr/bin/rtl_433 or /usr/local/bin/rtl_433
RTL433_BIN=rtl_433
RTL433_FREQ=433.92M

# MQTT Broker (Mosquitto running on this Pi)
MQTT_BROKER=mqtt://127.0.0.1:1883

# Claude API key (optional — for AI Intel panel)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX
